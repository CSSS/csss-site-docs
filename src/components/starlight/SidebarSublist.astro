---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';
import { Badge, Icon } from '@astrojs/starlight/components';
import SidebarRestorePoint from '@astrojs/starlight/components/SidebarRestorePoint.astro';
import { getLinkedSidebarGroupHref } from '../../sidebar';

type SidebarEntry = StarlightRouteData['sidebar'][number];
type SidebarLink = Extract<SidebarEntry, { type: 'link' }>;
type SidebarGroup = Extract<SidebarEntry, { type: 'group' }>;
type RenderEntry =
  | SidebarEntry
  | {
      type: 'hybrid';
      link: SidebarLink;
      entries: SidebarEntry[];
    };

interface Props {
  sublist: SidebarEntry[];
  nested?: boolean;
  path?: string[];
}

const { sublist, nested, path = [] } = Astro.props;

const normalizePathname = (pathname: string) =>
  pathname.endsWith('/') ? pathname : `${pathname}/`;
const titleCaseKebabLabel = (label: string) =>
  label
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
const hasCurrentEntry = (entries: SidebarEntry[]): boolean =>
  entries.some(entry => (entry.type === 'link' ? entry.isCurrent : hasCurrentEntry(entry.entries)));
const currentPathname = normalizePathname(Astro.url.pathname);

const getDescendantLinks = (entries: SidebarEntry[]): SidebarLink[] =>
  entries.flatMap(entry => (entry.type === 'link' ? [entry] : getDescendantLinks(entry.entries)));

const getAutogeneratedGroupHref = (entry: SidebarGroup) => {
  if (!('autogenerate' in entry)) return;

  const links = getDescendantLinks(entry.entries);
  if (links.length === 0) return;

  const segments = links.map(link => normalizePathname(link.href).split('/').filter(Boolean));
  const prefix = [...segments[0]];

  for (const pathSegments of segments.slice(1)) {
    while (
      prefix.length > 0 &&
      prefix.join('/') !== pathSegments.slice(0, prefix.length).join('/')
    ) {
      prefix.pop();
    }
  }

  return prefix.length > 0 ? `/${prefix.join('/')}/` : undefined;
};

const mergeAutogeneratedHybridEntries = (entries: SidebarEntry[]): RenderEntry[] => {
  const groupByHref = new Map<string, SidebarGroup>();
  const linkHrefs = new Set(
    entries
      .filter((entry): entry is SidebarLink => entry.type === 'link' && 'autogenerate' in entry)
      .map(entry => normalizePathname(entry.href))
  );

  for (const entry of entries) {
    if (entry.type !== 'group') continue;

    const href = getAutogeneratedGroupHref(entry);
    if (href && linkHrefs.has(href)) groupByHref.set(href, entry);
  }

  const mergedEntries: RenderEntry[] = [];

  for (const entry of entries) {
    if (entry.type === 'group') {
      const href = getAutogeneratedGroupHref(entry);
      const link = href
        ? entry.entries.find(
            (child): child is SidebarLink =>
              child.type === 'link' &&
              'autogenerate' in child &&
              normalizePathname(child.href) === href
          )
        : undefined;

      if (link) {
        mergedEntries.push({
          type: 'hybrid',
          link,
          entries: entry.entries.filter(child => child !== link)
        });
        continue;
      }

      if (groupByHref.get(getAutogeneratedGroupHref(entry) ?? '') !== entry) {
        mergedEntries.push(entry);
      }
      continue;
    }

    const group =
      'autogenerate' in entry ? groupByHref.get(normalizePathname(entry.href)) : undefined;
    mergedEntries.push(group ? { type: 'hybrid', link: entry, entries: group.entries } : entry);
  }

  return mergedEntries;
};

const renderSublist = mergeAutogeneratedHybridEntries(sublist);
---

<ul class:list={{ 'top-level': !nested }}>
  {
    renderSublist.map(entry => (
      <li>
        {entry.type === 'link' ? (
          <a
            href={entry.href}
            aria-current={entry.isCurrent ? 'page' : undefined}
            class:list={entry.attrs?.class ?? []}
            {...entry.attrs}
          >
            <span>{entry.label}</span>
            {entry.badge && (
              <Badge
                variant={entry.badge.variant}
                class={entry.badge.class}
                text={entry.badge.text}
              />
            )}
          </a>
        ) : entry.type === 'hybrid' ? (
          <>
            <a
              href={entry.link.href}
              aria-current={entry.link.isCurrent ? 'page' : undefined}
              class:list={entry.link.attrs.class ?? []}
              {...entry.link.attrs}
            >
              <span>{entry.link.label}</span>
              {entry.link.badge && (
                <Badge
                  variant={entry.link.badge.variant}
                  class={entry.link.badge.class}
                  text={entry.link.badge.text}
                />
              )}
            </a>
            <Astro.self sublist={entry.entries} nested path={path} />
          </>
        ) : (
          (() => {
            const entryPath = [...path, entry.label];
            const href = getLinkedSidebarGroupHref(entryPath);
            const label = 'autogenerate' in entry ? titleCaseKebabLabel(entry.label) : entry.label;
            const isCurrent = href && normalizePathname(href) === currentPathname;
            const hasCurrentChild = hasCurrentEntry(entry.entries);

            return href ? (
              <>
                <a
                  href={href}
                  aria-current={isCurrent ? 'page' : undefined}
                  class:list={{ large: !nested }}
                >
                  <span>{entry.label}</span>
                  {entry.badge && (
                    <Badge
                      variant={entry.badge.variant}
                      class={entry.badge.class}
                      text={entry.badge.text}
                    />
                  )}
                </a>
                <Astro.self sublist={entry.entries} nested path={entryPath} />
              </>
            ) : (
              <details open={hasCurrentChild || !entry.collapsed}>
                <summary>
                  <span class="group-label">
                    <span class="large">{label}</span>
                    {entry.badge && (
                      <Badge
                        variant={entry.badge.variant}
                        class={entry.badge.class}
                        text={entry.badge.text}
                      />
                    )}
                  </span>
                  <Icon name="right-caret" class="caret" size="1.25rem" />
                </summary>
                <SidebarRestorePoint />
                <Astro.self sublist={entry.entries} nested path={entryPath} />
              </details>
            );
          })()
        )}
      </li>
    ))
  }
</ul>

<style>
  @layer starlight.core {
    ul {
      --sl-sidebar-item-padding-inline: 0.5rem;
      list-style: none;
      padding: 0;
    }

    li {
      overflow-wrap: anywhere;
    }

    ul ul li {
      margin-inline-start: var(--sl-sidebar-item-padding-inline);
      border-inline-start: 1px solid var(--sl-color-hairline-light);
      padding-inline-start: var(--sl-sidebar-item-padding-inline);
    }

    .large {
      font-size: var(--sl-text-lg);
      font-weight: 600;
      color: var(--sl-color-white);
    }

    .top-level > li + li {
      margin-top: 0.75rem;
    }

    summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.2em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
      cursor: pointer;
      user-select: none;
    }

    summary::marker,
    summary::-webkit-details-marker {
      display: none;
    }

    .caret {
      transition: transform 0.2s ease-in-out;
      flex-shrink: 0;
    }

    :global([dir='rtl']) .caret {
      transform: rotateZ(180deg);
    }

    [open] > summary .caret {
      transform: rotateZ(90deg);
    }

    a {
      display: block;
      border-radius: 0.25rem;
      text-decoration: none;
      color: var(--sl-color-gray-2);
      padding: 0.3em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
    }

    a:hover,
    a:focus {
      color: var(--sl-color-white);
    }

    [aria-current='page'],
    [aria-current='page']:hover,
    [aria-current='page']:focus {
      font-weight: 600;
      color: var(--sl-color-text-invert);
      background-color: var(--sl-color-text-accent);
    }

    a > *:not(:last-child),
    .group-label > *:not(:last-child) {
      margin-inline-end: 0.25em;
    }

    @media (min-width: 50rem) {
      .top-level > li + li {
        margin-top: 0.5rem;
      }

      .large {
        font-size: var(--sl-text-base);
      }

      a {
        font-size: var(--sl-text-sm);
      }
    }
  }
</style>
